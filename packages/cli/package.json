{
  "name": "@deckel/cli",
  "version": "0.1.0",
  "description": "Local in-repo sprint & security cockpit CLI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "deckel": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @deckel/ui build && tsup && node scripts/copy-ui.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@deckel/server": "workspace:*",
    "@deckel/ui": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "hono": "^4.6.13",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "valibot": "^0.42.1",
    "vitest": "^2.1.8"
  }
}
