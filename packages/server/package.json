{
  "name": "@dckl/server",
  "version": "0.1.0",
  "description": "Hono server for dckl",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./storage": "./src/storage/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "echo 'server is imported as source by @dckl/cli — no build step'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.13",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.2",
    "valibot": "^0.42.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
